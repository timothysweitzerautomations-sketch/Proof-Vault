# Database (PostgreSQL required for production / Vercel)
# Local: Homebrew Postgres (brew services start postgresql@16) on 5432, or Docker (docker compose up -d) on 5433.
# Docker: postgresql://vault:vault@localhost:5433/vault
DATABASE_URL="postgresql://vault:vault@localhost:5432/vault"

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-string"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional if using GitHub only)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub OAuth (optional if using Google only)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# App URL for emails (fallback: VERCEL_URL on Vercel)
APP_URL="http://localhost:3000"

# Optional: only for `npm run android:apk:prod -- https://…` (overrides APP_URL in .env for that build)
# PROOF_VAULT_SERVER_URL="https://your-deployment.example.com"

# Email (Resend) — https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="Proof Vault <onboarding@resend.dev>"

# Cron — protect /api/cron/reminders (Vercel injects Bearer when CRON_SECRET is set)
CRON_SECRET="replace-with-random-string"

# File uploads on Vercel — create Blob store and token
BLOB_READ_WRITE_TOKEN=""
